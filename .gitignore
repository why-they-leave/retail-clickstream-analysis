*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python

# 가상환경
.venv/
venv/
env/
ENV/
retail-clickstream-analysis/

# 환경변수 / 시크릿
.env
.env.*
!.env.example
secrets/
credentials/

# 데이터 (원본 데이터는 추적하지 않음)
data/raw/
data/interim/*
data/processed/*
data/outputs/ALS/*

# Issue #17: segment naming 산출물은 #18 비교 리포트 입력으로 재사용되어 예외 추적
# Issue #23: US-only 트랙 제거 — Full 산출물만 예외 추적
!data/processed/segment_summary_all_customers.csv
!data/processed/segment_personas_v2.json

# Issue #31: train 기간 한정 세그먼트 이름/정의 — LightGCN(#29)이 실제로 쓰는 버전.
# LLM naming(temperature 사용)이라 재생성하면 결과가 달라져 canonical 파일만 공유
# (segment_personas_v2.json과 동일한 패턴). 고객별 전체 배정 CSV(27MB, customer_segments_labeled_train_only.csv)는
# 요청 범위 밖이라 제외 — 필요해지면 그때 예외 추가.
!data/processed/segment_personas_train_only.json

# v1 GPLR 페르소나 생성 결과 — LLM temperature=0.7이라 실행할 때마다 결과가 달라짐.
# 팀원마다 재생성하지 않고 canonical 산출물만 공유하기 위해 예외 추적 (v2와 동일한 패턴)
!data/interim/funnel_persona_gen/
!data/interim/funnel_persona_gen_us/
data/interim/funnel_persona_gen/*
data/interim/funnel_persona_gen_us/*
!data/interim/funnel_persona_gen/final_personas.json
!data/interim/funnel_persona_gen_us/final_personas.json

